# =============================================================================
# SpaceGuard - Production Environment Variables
# Copy to .env.production and fill in real values before deploying
# =============================================================================

# ---------------------------------------------------------------------------
# Domain (used by nginx and certbot)
# ---------------------------------------------------------------------------
DOMAIN=spaceguard.example.com

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=spaceguard
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_here
POSTGRES_DB=spaceguard

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_another_strong_password

# ---------------------------------------------------------------------------
# API (Hono backend)
# ---------------------------------------------------------------------------

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# AES-256 encryption key for sensitive data at rest (exactly 64 hex chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

# Public URL for the API (as seen by the browser)
# In production with nginx, the browser hits the same domain and nginx routes
# /api/* to the backend, so this should be your public domain
NEXT_PUBLIC_API_URL=https://spaceguard.example.com

# ---------------------------------------------------------------------------
# SSL (Let's Encrypt)
# ---------------------------------------------------------------------------
CERTBOT_EMAIL=admin@example.com
