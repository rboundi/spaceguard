{
  "name": "spaceguard",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "npm run db:generate --workspace=apps/api",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:seed": "npx tsx seed-data/seed.ts",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.7",
    "tsx": "^4"
  }
}
